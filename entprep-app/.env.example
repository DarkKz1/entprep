# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic (server-side, Netlify functions — ai-explain, ai-generate, ai-plan)
ANTHROPIC_API_KEY=sk-ant-...

# Admin access (comma-separated emails)
ADMIN_EMAILS=admin@example.com
VITE_ADMIN_EMAILS=admin@example.com

# CORS (optional, defaults to https://entprep.netlify.app)
ALLOWED_ORIGIN=https://entprep.netlify.app

# Sentry (optional, error monitoring)
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Push notifications (VAPID keys — generate with: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=BPxxx...
VAPID_PRIVATE_KEY=xxx...
VAPID_SUBJECT=mailto:admin@example.com
